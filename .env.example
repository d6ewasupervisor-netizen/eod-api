# ─── Core ───────────────────────────────────────────────────────────────────
PORT=3001
DATABASE_URL=
RESEND_API_KEY=

# TLS mode for Postgres. Leave unset to honor sslmode= in DATABASE_URL.
# disable | require | no-verify | verify-full
# Railway public TCP proxy: require. Railway *.railway.internal: leave unset.
# PGSSL=

# ─── Auth mode (Cloudflare Access removal migration) ────────────────────────
# 'cf-access' (default) keeps the existing Cloudflare-Access-JWT verification.
# 'session'   switches the global gate to verify our own session JWT (issued
#             by /api/verify-token after a magic-link click). Flip to 'session'
#             only after the new signin.html + admin.html are deployed and
#             tested. Switching back to 'cf-access' on Railway is a one-line
#             rollback as long as the CF Access apps are still enabled.
AUTH_MODE=cf-access

# Secret used by issueLinkToken / issueSessionToken / issueAdminSessionToken.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Required in both AUTH_MODE values once /api/request-link, /api/verify-token,
# /api/admin/session, /api/access-request are reachable -- they always sign with
# this even while CF Access still gates the rest of the API.
JWT_SECRET=

# How long a magic link is valid (days). Default 30.
LINK_TTL_DAYS=30

# How long the long-lived session JWT lasts after a magic link is consumed.
# Default 45 days.
SESSION_TTL_DAYS=45

# Where the the-dump-bin frontend lives. Used to build magic-link URLs (the
# user lands on the hub home / and picks an app) and the admin password-reset
# URL (which points at /admin.html). No trailing slash, no /EOD suffix --
# the sign-in flow now covers every app under the-dump-bin.com.
FRONTEND_BASE_URL=https://the-dump-bin.com

# Static site origin for supervisor review links (decide.html). Defaults to https://the-dump-bin.com
# DUMP_BIN_SITE=https://the-dump-bin.com

# Public base URL of THIS API. Used to build approve/deny URLs in the
# access-request approver email. Defaults to https://${RAILWAY_PUBLIC_DOMAIN}
# (set automatically by Railway) and finally to eod-api.the-dump-bin.com.
# BACKEND_BASE_URL=https://eod-api.the-dump-bin.com

# Comma-separated approvers who receive the access-request emails.
# Defaults to tyson.gauthier@retailodyssey.com.
# ACCESS_REQUEST_APPROVERS=tyson.gauthier@retailodyssey.com

# HMAC key signing the approve/deny URLs in the access-request approver email.
# Without this the approve/deny buttons return "Configuration error".
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_REQUEST_SECRET=

# Primary admin email pre-seeded into site_admins. The first time this row's
# password_hash is NULL, POSTing the value of ADMIN_SETUP_TOKEN below to
# /api/admin/session/setup unlocks the slot so the admin can choose a password.
# After the password is set the env var below can be cleared.
# PRIMARY_ADMIN_EMAIL=tyson.gauthier@retailodyssey.com
# ADMIN_SETUP_TOKEN=

# Optional admin tuning.
# ADMIN_SESSION_DAYS=45
# ADMIN_PASSWORD_MIN_LENGTH=10
# ADMIN_BCRYPT_COST=12
# ADMIN_INVITE_TTL_DAYS=7

# ─── Cloudflare Access auth (legacy, used only while AUTH_MODE=cf-access) ───
# After AUTH_MODE flips to 'session' for good (and the CF Access app is
# disabled in Zero Trust), these can be removed.
#   Settings → Custom Pages → "Team domain"        →  CF_ACCESS_TEAM_DOMAIN
#   Access → Applications → eod-api app → Overview → AUD tag → CF_ACCESS_AUD
CF_ACCESS_TEAM_DOMAIN=retailodyssey.cloudflareaccess.com
CF_ACCESS_AUD=

# CORS — origins allowed to send credentialed requests to this API.
# Comma-separated. Defaults to https://the-dump-bin.com if unset.
ALLOWED_ORIGINS=https://the-dump-bin.com

# ─── Role allowlists (comma-separated emails, case-insensitive) ─────────────
KOMPASS_ADMIN_EMAILS=
KOMPASS_SUPERVISOR_EMAILS=
KOMPASS_LEAD_EMAILS=

# EOD cover sheet API + SPA gate (comma-separated). Used ONLY while
# AUTH_MODE=cf-access. After AUTH_MODE=session, the same list lives in the
# Postgres allowed_emails table (seeded by migration 002 on first boot) and
# is managed from https://the-dump-bin.com/admin.html -- this env var has
# no effect in session mode.
EOD_APP_ALLOWED_EMAILS=aiyana.natarisalazar@retailodyssey.com,alex.wright2@retailodyssey.com,james.duchene@retailodyssey.com,jes.zumwalt@sasretailservices.com,ruth.northcutt@sasretailservices.com,d6ewa.supervisor@gmail.com

# ─── Daily store confirmation gate ──────────────────────────────────────────
# REQUIRED on Railway. HMAC-SHA256 secret used to sign day-confirm tokens that
# unlock /send-eod and /instawork/save-image. Without it, both routes fail
# closed (every request returns 412 day_confirm_required). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DAY_CONFIRM_SECRET=

# Recipient of off-roster override approval emails. Defaults to
# tyson.gauthier@retailodyssey.com if unset.
OVERRIDE_APPROVER_EMAIL=

# Checklanes / set-related email (Resend). Domain checklanes@retail-odyssey.com must be verified.
# CHECKLANES_EMAIL_FROM=Checklanes <checklanes@retail-odyssey.com>
# CHECKLANES_OPS_EMAIL=tyson.gauthier@retailodyssey.com

# KOMPASS Help Desk ticket routing. During the test phase, tickets are NOT sent
# to kompass@retail-odyssey.com: instead To = HELPDESK_TEST_TO, CC = the person
# who initiated the ticket, and Reply-To = that same initiator.
# Set HELPDESK_TEST_MODE=off (or false/0/no) for normal go-live delivery.
# HELPDESK_TEST_MODE=on
# HELPDESK_TEST_TO=tyson.gauthier@retailodyssey.com

# Checklane Hub off-Railway backup snapshots (Resend, JSON attachment).
# Falls back to OVERRIDE_APPROVER_EMAIL, then KOMPASS_SUPERVISOR_EMAILS.
# HUB_BACKUP_EMAIL=

# Checklane Hub verified missing-tag batch PDF (spa gun shelf tags).
# To: tyson.gauthier@retailodyssey.com (CHECKLANES_OPS_EMAIL). CC: sender.
# Subject during testing: #999. Live: #31, #163, etc. (see tagBatchEmailSubjectLive).
# HUB_TAG_BATCH_EMAIL=

# Resend "from" address for override emails. Must be a verified Resend sender.
# Defaults to shifts@retail-odyssey.com (same as shift-management.js).
OVERRIDE_FROM_ADDRESS=

# ─── Existing app config (kept) ─────────────────────────────────────────────
KOMPASS_ADMIN_USERNAMES=Tyson.Gauthier
KOMPASS_D8_REBOTICS_STORES=
SAS_AUTH_SECRET=
GITHUB_PAT=

# ─── AI chat (extension side panel) ────────────────────────────────────────
# Anthropic API key used by POST /api/ai/chat. Without it the route returns
# 500 and /api/ai/health reports configured:false.
ANTHROPIC_API_KEY=
# Optional override (default: claude-sonnet-4-5).
ANTHROPIC_MODEL=

# When the extension calls /api/ai/*, its origin (chrome-extension://<id>)
# must be on ALLOWED_ORIGINS above. Pin the extension ID via manifest `key`
# so the origin is stable across reinstalls — then add e.g.
#   ALLOWED_ORIGINS=https://the-dump-bin.com,chrome-extension://abcdef…

# ─── Dump bin browser (/dump-bin/) ───────────────────────────────────────────
# SharePoint drive that holds the Dump Bin document library. Uses the same
# Microsoft Graph app-only credentials as InstaWork (INSTAWORK_AAD_* / MICROSOFT_*).
# Required for GET /api/list, /api/download, /api/download-token.
# DUMP_BIN_SP_DRIVE_ID=
# Optional: short-lived JWT for ?t= on download links (default 45m).
# DUMP_BIN_DOWNLOAD_TTL_MINUTES=45

