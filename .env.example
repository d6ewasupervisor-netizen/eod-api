# ─── Core ───────────────────────────────────────────────────────────────────
PORT=3001
DATABASE_URL=
RESEND_API_KEY=

# ─── Cloudflare Access auth ─────────────────────────────────────────────────
# Required. Obtained from the Cloudflare Zero Trust dashboard.
#   Settings → Custom Pages → "Team domain"        →  CF_ACCESS_TEAM_DOMAIN
#   Access → Applications → eod-api app → Overview → AUD tag → CF_ACCESS_AUD
CF_ACCESS_TEAM_DOMAIN=retailodyssey.cloudflareaccess.com
CF_ACCESS_AUD=

# CORS — origins allowed to send credentialed requests to this API.
# Comma-separated. Defaults to https://the-dump-bin.com if unset.
ALLOWED_ORIGINS=https://the-dump-bin.com

# ─── Role allowlists (comma-separated emails, case-insensitive) ─────────────
KOMPASS_ADMIN_EMAILS=
KOMPASS_SUPERVISOR_EMAILS=
KOMPASS_LEAD_EMAILS=

# ─── Existing app config (kept) ─────────────────────────────────────────────
KOMPASS_ADMIN_USERNAMES=Tyson.Gauthier
KOMPASS_D8_REBOTICS_STORES=
SAS_AUTH_SECRET=
GITHUB_PAT=
