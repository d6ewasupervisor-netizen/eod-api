# Hosted API root. Do not include a trailing slash.
API_BASE_URL=https://eod-api.the-dump-bin.com

# Bearer token matching TRACKER_INGEST_TOKEN on the server.
TRACKER_INGEST_TOKEN=replace-with-local-secret

# Absolute local OneDrive workbook paths.
ISE_WORKBOOK_PATH=C:\Users\you\OneDrive - Advantage Solutions\Auston Nix's files\SUPER Tracker ISE V1.3.xlsm
BLITZ_WORKBOOK_PATH=C:\Users\you\OneDrive - Advantage Solutions\Auston Nix's files\SUPER Tracker Blitz V1.3.xlsx

# Optional CSV force list for deliberate clears/period rollover: ise, blitz, or ise,blitz.
TRACKER_INGEST_FORCE_KIND=

# Optional local log directory. Defaults to agent/logs.
LOG_DIR=

# Optional local pre-POST floor. Defaults to 50.
LOCAL_FLOOR=50
