# Optional. Defaults to this URL if unset.
KOMPASS_DS_QUERY_URL=https://krcs-reporting.rebotics.net/api/ds/query

# Supply the live Grafana session one of two ways:
# 1. Export KOMPASS_GRAFANA_COOKIE with the raw Cookie header value.
# 2. Put the raw Cookie header value on one line in scripts/kompass-proof/.cookie.
#
# Capture the cookie fresh from browser DevTools immediately before running.
# Never commit .env or .cookie.
#
# KOMPASS_GRAFANA_COOKIE=grafana_session=...; grafana_session_expiry=...
